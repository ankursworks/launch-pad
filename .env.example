# API base URL the in-app `api()` helper hits. Default works against the
# bundled mock; replace with your real backend when you're ready.
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ────────────────────────────────────────────────────────────────────────────
# Authentication
# ────────────────────────────────────────────────────────────────────────────
# Auth backend selector. `mock` (default) uses an in-memory fake — any email
# + 6+ char password succeeds, persisted to localStorage. `clerk` activates
# real Clerk auth (sessions, OAuth, email verification, password reset).
NEXT_PUBLIC_AUTH_MODE=mock

# Clerk keys — only required when NEXT_PUBLIC_AUTH_MODE=clerk.
# Grab these from https://dashboard.clerk.com/ → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional Clerk URL overrides — leave blank for sensible defaults.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
